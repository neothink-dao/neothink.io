{
  "name": "@neothink/monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "node build.js",
    "dev": "turbo run dev",
    "dev:hub": "turbo run dev --filter=hub",
    "dev:ascenders": "turbo run dev --filter=ascenders",
    "dev:immortals": "turbo run dev --filter=immortals",
    "dev:neothinkers": "turbo run dev --filter=neothinkers",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "clean:packages": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "type-check": "turbo run type-check",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "supabase:deploy": "turbo run supabase:deploy"
  },
  "devDependencies": {
    "@types/node": "^20.11.25",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "turbo": "^1.12.5",
    "typescript": "^5.4.2",
    "vitest": "^1.3.1",
    "@vitejs/plugin-react": "^4.2.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@8.15.4",
  "pnpm": {
    "overrides": {
      "next": "^14.1.3"
    }
  }
}
