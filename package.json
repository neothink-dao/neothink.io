{
  "name": "@neothink/monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:hub": "turbo run dev --filter=hub",
    "dev:ascenders": "turbo run dev --filter=ascenders",
    "dev:immortals": "turbo run dev --filter=immortals",
    "dev:neothinkers": "turbo run dev --filter=neothinkers",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "clean:packages": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.39",
    "@types/react-dom": "^18.2.17",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "turbo": "^1.10.16",
    "typescript": "^5.2.2",
    "vitest": "^1.0.0",
    "@vitejs/plugin-react": "^4.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@8.10.5",
  "pnpm": {
    "overrides": {
      "next": "^14.0.3"
    }
  }
}
