{
  "name": "neothink-platforms",
  "version": "1.0.0",
  "description": "Monorepo for Neothink platforms and apps",
  "private": true,
  "workspaces": [
    "go.neothink.io",
    "joinascenders",
    "joinneothinkers",
    "joinimmortals"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "deploy:hub": "node scripts/deploy-platforms.js hub",
    "deploy:ascenders": "node scripts/deploy-platforms.js ascenders",
    "deploy:neothinkers": "node scripts/deploy-platforms.js neothinkers",
    "deploy:immortals": "node scripts/deploy-platforms.js immortals",
    "deploy:all": "npm run deploy:hub && npm run deploy:ascenders && npm run deploy:neothinkers && npm run deploy:immortals",
    "deploy:dev": "node scripts/deploy-platforms.js",
    "sync:roles": "node scripts/sync-role-system.js",
    "prepare:deploy": "node scripts/prepare-deploy.js",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "migrate": "ts-node scripts/apply-migrations.ts",
    "migrate:js": "node scripts/apply-migrations.js",
    "verify": "ts-node scripts/verify-changes.ts",
    "migrate:analytics": "ts-node scripts/apply-single-migration.ts 20240406_01_analytics_tables.sql",
    "migrate:notifications": "ts-node scripts/apply-single-migration.ts 20240406_02_notification_tables.sql",
    "migrate:content": "ts-node scripts/apply-single-migration.ts 20240407_01_shared_content_tables.sql",
    "migrate:comments": "ts-node scripts/apply-single-migration.ts 20240408_01_content_comments_tables.sql",
    "migrate:subscriptions": "ts-node scripts/apply-single-migration.ts 20240409_01_subscription_management.sql",
    "migrate:security": "ts-node scripts/apply-single-migration.ts 20240606_security_enhancements.sql",
    "migrate:all": "npm run migrate",
    "gen:types": "supabase gen types typescript --project-id dlmpxgzxdtqxyzsmpaxx --schema public > types/supabase.ts",
    "security:audit": "npm audit fix && npm audit",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "ui:add": "npx shadcn-ui@latest add",
    "ui:init": "npx shadcn-ui@latest init"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-aspect-ratio": "^1.0.3",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-context-menu": "^2.1.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-hover-card": "^1.0.7",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-menubar": "^1.0.4",
    "@radix-ui/react-navigation-menu": "^1.1.4",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-toggle": "^1.0.3",
    "@radix-ui/react-toggle-group": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/ssr": "^0.1.0",
    "@supabase/supabase-js": "^2.39.7",
    "autoprefixer": "^10.4.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.3.1",
    "dotenv": "^16.4.5",
    "framer-motion": "^11.1.6",
    "glob": "^11.0.1",
    "lucide-react": "^0.359.0",
    "next": "^15.2.4",
    "next-themes": "^0.2.1",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-day-picker": "^8.10.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.51.0",
    "rimraf": "^6.0.1",
    "sonner": "^1.4.3",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "ts-node": "^10.9.2",
    "vaul": "^0.9.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.67",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.5.0",
    "@typescript-eslint/parser": "^7.5.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.2.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.12",
    "supabase": "^1.145.4",
    "tsup": "^8.0.2",
    "turbo": "^1.13.4",
    "typescript": "^5.4.2"
  },
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.6.0"
  }
}
