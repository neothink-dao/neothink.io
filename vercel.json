{
  "framework": "nextjs",
  "buildCommand": "turbo run build",
  "devCommand": "pnpm run dev",
  "installCommand": "npx pnpm@10 install --no-frozen-lockfile",
  "outputDirectory": ".next",
  "git": {
    "deploymentEnabled": true
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/auth/(.*)", "destination": "/api/auth/$1" },
    { "source": "/api/supabase/(.*)", "destination": "/api/supabase/$1" }
  ],
  "regions": ["iad1"],
  "functions": {
    "api/**/*": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "env": {
    "NEXT_PUBLIC_VERCEL_ENV": "production",
    "NEXT_PUBLIC_PLATFORM_NAME": "Neothink",
    "NEXT_PUBLIC_SUPABASE_URL": "https://neothink.supabase.co",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "@supabase_anon_key",
    "SUPABASE_SERVICE_ROLE_KEY": "@supabase_service_role_key"
  },
  "workspaces": [
    {
      "name": "go.neothink.io",
      "path": "go.neothink.io",
      "outputDirectory": "go.neothink.io/.next",
      "env": {
        "NEXT_PUBLIC_PLATFORM_NAME": "Neothink Hub",
        "NEXT_PUBLIC_BASE_URL": "https://go.neothink.io"
      }
    },
    {
      "name": "joinascenders",
      "path": "joinascenders",
      "outputDirectory": "joinascenders/.next",
      "env": {
        "NEXT_PUBLIC_PLATFORM_NAME": "Ascenders",
        "NEXT_PUBLIC_BASE_URL": "https://joinascenders.com"
      }
    },
    {
      "name": "joinneothinkers",
      "path": "joinneothinkers",
      "outputDirectory": "joinneothinkers/.next",
      "env": {
        "NEXT_PUBLIC_PLATFORM_NAME": "Neothinkers",
        "NEXT_PUBLIC_BASE_URL": "https://joinneothinkers.com"
      }
    },
    {
      "name": "joinimmortals",
      "path": "joinimmortals",
      "outputDirectory": "joinimmortals/.next",
      "env": {
        "NEXT_PUBLIC_PLATFORM_NAME": "Immortals",
        "NEXT_PUBLIC_BASE_URL": "https://joinimmortals.com"
      }
    }
  ]
} 