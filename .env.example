# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Authentication
NEXT_PUBLIC_AUTH_COOKIE_DOMAIN=.neothink.io
AUTH_SECRET=your-auth-secret
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret

# Analytics and Monitoring
NEXT_PUBLIC_ANALYTICS_URL=your-analytics-url
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=your-posthog-host

# Platform-Specific URLs
NEXT_PUBLIC_HUB_URL=http://localhost:3000
NEXT_PUBLIC_ASCENDERS_URL=http://localhost:3001
NEXT_PUBLIC_NEOTHINKERS_URL=http://localhost:3002
NEXT_PUBLIC_IMMORTALS_URL=http://localhost:3003

# API Keys and External Services
OPENAI_API_KEY=your-openai-key
STRIPE_SECRET_KEY=your-stripe-secret
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable

# Email Configuration
EMAIL_SERVER_HOST=localhost
EMAIL_SERVER_PORT=1025
EMAIL_SERVER_USER=your-email-user
EMAIL_SERVER_PASSWORD=your-email-password
EMAIL_FROM=noreply@neothink.io

# Cache and Performance
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600
REVALIDATE_TOKEN=your-revalidate-token

# Feature Flags
NEXT_PUBLIC_FEATURE_CHAT=true
NEXT_PUBLIC_FEATURE_AI=true
NEXT_PUBLIC_FEATURE_ANALYTICS=true

# Development Settings
NODE_ENV=development
DEBUG=app:*
NEXT_TELEMETRY_DISABLED=1

# Security
CSP_REPORT_ONLY=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# Deployment
VERCEL_URL=localhost:3000
VERCEL_ENV=development
VERCEL_GIT_COMMIT_SHA=local
VERCEL_GIT_COMMIT_REF=local

# Documentation
NEXT_PUBLIC_DOCS_URL=http://localhost:3005

# Platform-specific
NEXT_PUBLIC_PLATFORM_NAME=Hub
NEXT_PUBLIC_PLATFORM_SLUG=hub
NEXT_PUBLIC_BASE_URL=https://go.neothink.io

# Analytics
NEXT_PUBLIC_POSTHOG_API_KEY=

# Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Turborepo
TURBO_TEAM=neothink-dao

# Vercel
VERCEL_ENV=production
VERCEL_URL=
VERCEL_GIT_COMMIT_SHA=

# Node
NODE_ENV=production

# Platform Access
NEXT_PUBLIC_ENABLE_HUB=true
NEXT_PUBLIC_ENABLE_ASCENDERS=true
NEXT_PUBLIC_ENABLE_NEOTHINKERS=true
NEXT_PUBLIC_ENABLE_IMMORTALS=true

# Database configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=your_database_name
POSTGRES_USER=your_database_user
POSTGRES_PASSWORD=your_database_password

# Application settings
NODE_ENV=development

# MCP server configuration
MCP_API_KEY=your_mcp_api_key

# Optional: Database Configuration
# DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres
# DATABASE_POOL_SIZE=5
# DATABASE_TIMEOUT=5000 