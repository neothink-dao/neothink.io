# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://dlmpxgzxdtqxyzsmpaxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Platform-specific
