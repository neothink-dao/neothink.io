{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@neothink/analytics/*": ["./src/*"],
      "@neothink/core/*": ["../core/*"],
      "@neothink/types": ["../types/src"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
} 